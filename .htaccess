RewriteEngine On

# Compatibilità protocollo DynDNS2 / No-IP
# I router inviano richieste a /nic/update
RewriteRule ^nic/update$ update.php [L,QSA]

# Blocca accesso diretto alla cartella data/ (SQLite, file init, ecc.)
<IfModule mod_authz_core.c>
    <DirectoryMatch "data/">
        Require all denied
    </DirectoryMatch>
</IfModule>
<FilesMatch "\.(sqlite|sqlite-wal|sqlite-shm|txt)$">
    Require all denied
</FilesMatch>
